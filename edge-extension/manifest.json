{
  "manifest_version": 3,
  "name": "Bing Rewards Automator",
  "version": "1.0.0",
  "description": "Automate Bing Rewards searches with manual and automatic controls. Optimized for anti-detection.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://www.bing.com/*",
    "*://ipapi.co/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Bing Rewards Automator"
  },
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.bing.com/*"],
      "js": ["src/content-script.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "src/options.html",
  "web_accessible_resources": [
    {
      "resources": ["src/injected.js"],
      "matches": ["*://www.bing.com/*"]
    }
  ]
}
